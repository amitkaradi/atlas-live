# Netlify: the LAST matching rule wins — generic first, specific after.
# Media is versioned by folder/name — if frames/videos ever change, rename
# (frames2 → frames3, *_hq → *_hq2) so returning visitors never see a stale mix.
/assets/*
  Cache-Control: public, max-age=86400
/assets/frames2/*
  Cache-Control: public, max-age=604800
/assets/frames2-sm/*
  Cache-Control: public, max-age=604800
/assets/video/*
  Cache-Control: public, max-age=604800
